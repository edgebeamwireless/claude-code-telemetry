# Copy to .env and fill in. .env is gitignored — never commit it.

# Grafana admin password. docker-compose.yml reads this via ${GRAFANA_ADMIN_PASSWORD}.
GRAFANA_ADMIN_PASSWORD=

# Shared OTLP ingest token. Clients must send `Authorization: Bearer <this>` or
# their telemetry push is rejected. Generate with: openssl rand -hex 32
# The collector reads it (via docker-compose) and clients use it in
# OTEL_EXPORTER_OTLP_HEADERS (see bootstrap-claude-telemetry.sh).
OTEL_INGEST_TOKEN=
